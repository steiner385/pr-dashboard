{
  "name": "plotroom",
  "version": "0.1.2",
  "description": "Embeddable CI/CD + pull-request operations dashboard — watch GitHub Actions pipeline health, runner timing and critical path, and PR merge-readiness, with one-click ready-to-merge / draft levers. Ships a React component (./embed) and a mountable Express backend (./server).",
  "type": "module",
  "license": "MIT",
  "author": "Tony Stein",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steiner385/plotroom.git"
  },
  "homepage": "https://github.com/steiner385/plotroom#readme",
  "bugs": "https://github.com/steiner385/plotroom/issues",
  "keywords": [
    "ci",
    "cd",
    "github-actions",
    "pull-request",
    "dashboard",
    "pipeline",
    "merge-readiness",
    "devops",
    "react",
    "embeddable"
  ],
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "build:embed": "vite build --config vite.embed.config.ts",
    "embed:harness": "pnpm build:embed && vite --config embed-harness/vite.config.ts",
    "prepare": "pnpm build:embed && pnpm build:server",
    "start": "NODE_ENV=production tsx server/index.ts",
    "app:setup": "tsx scripts/app-setup.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "service:install": "bash scripts/install-service.sh",
    "build:server": "tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json -f"
  },
  "files": [
    "dist/embed",
    "dist/server"
  ],
  "exports": {
    "./embed": {
      "types": "./dist/embed/index.d.ts",
      "import": "./dist/embed/index.js"
    },
    "./embed/style.css": "./dist/embed/style.css",
    "./server": {
      "types": "./dist/server/server/backend.d.ts",
      "import": "./dist/server/server/backend.js"
    }
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^4.22.2",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "postcss-prefix-selector": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
